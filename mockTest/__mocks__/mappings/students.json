{
  "request": {
    "method": "POST",
    "url": "/userinfo/graphql",
    "bodyPatterns": [
      {
        "matches": ".*students\\s*\\{.*items.*\\}.*"
      }
    ]
  },
  "response": {
    "status": 200,
    "bodyFileName": "students-response.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
