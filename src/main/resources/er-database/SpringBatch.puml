@startuml
entity "BATCH_JOB_INSTANCE" {
  * JOB_INSTANCE_ID : BIGINT <<PK>>
  --
  VERSION : BIGINT
  JOB_NAME : VARCHAR(100)
  JOB_KEY : VARCHAR(32)
  --
  {unique} JOB_INST_UN(JOB_NAME, JOB_KEY)
}

entity "BATCH_JOB_EXECUTION" {
  * JOB_EXECUTION_ID : BIGINT <<PK>>
  --
  VERSION : BIGINT
  JOB_INSTANCE_ID : BIGINT <<FK>>
  CREATE_TIME : TIMESTAMP
  START_TIME : TIMESTAMP
  END_TIME : TIMESTAMP
  STATUS : VARCHAR(10)
  EXIT_CODE : VARCHAR(2500)
  EXIT_MESSAGE : VARCHAR(2500)
  LAST_UPDATED : TIMESTAMP
}

entity "BATCH_JOB_EXECUTION_PARAMS" {
  * JOB_EXECUTION_ID : BIGINT <<FK>>
  * PARAMETER_NAME : VARCHAR(100)
  * PARAMETER_TYPE : VARCHAR(100)
  * PARAMETER_VALUE : VARCHAR(2500)
  * IDENTIFYING : CHAR(1)
}

entity "BATCH_STEP_EXECUTION" {
  * STEP_EXECUTION_ID : BIGINT <<PK>>
  --
  VERSION : BIGINT
  STEP_NAME : VARCHAR(100)
  JOB_EXECUTION_ID : BIGINT <<FK>>
  CREATE_TIME : TIMESTAMP
  START_TIME : TIMESTAMP
  END_TIME : TIMESTAMP
  STATUS : VARCHAR(10)
  COMMIT_COUNT : BIGINT
  READ_COUNT : BIGINT
  FILTER_COUNT : BIGINT
  WRITE_COUNT : BIGINT
  READ_SKIP_COUNT : BIGINT
  WRITE_SKIP_COUNT : BIGINT
  PROCESS_SKIP_COUNT : BIGINT
  ROLLBACK_COUNT : BIGINT
  EXIT_CODE : VARCHAR(2500)
  EXIT_MESSAGE : VARCHAR(2500)
  LAST_UPDATED : TIMESTAMP
}

entity "BATCH_STEP_EXECUTION_CONTEXT" {
  * STEP_EXECUTION_ID : BIGINT <<PK,FK>>
  --
  SHORT_CONTEXT : VARCHAR(2500)
  SERIALIZED_CONTEXT : TEXT
}

entity "BATCH_JOB_EXECUTION_CONTEXT" {
  * JOB_EXECUTION_ID : BIGINT <<PK,FK>>
  --
  SHORT_CONTEXT : VARCHAR(2500)
  SERIALIZED_CONTEXT : TEXT
}

BATCH_JOB_INSTANCE ||--o{ BATCH_JOB_EXECUTION : JOB_INSTANCE_ID
BATCH_JOB_EXECUTION ||--o{ BATCH_JOB_EXECUTION_PARAMS : JOB_EXECUTION_ID
BATCH_JOB_EXECUTION ||--o{ BATCH_STEP_EXECUTION : JOB_EXECUTION_ID
BATCH_STEP_EXECUTION ||--o| BATCH_STEP_EXECUTION_CONTEXT : STEP_EXECUTION_ID
BATCH_JOB_EXECUTION ||--o| BATCH_JOB_EXECUTION_CONTEXT : JOB_EXECUTION_ID

hide circle
@enduml